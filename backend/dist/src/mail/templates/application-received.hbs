<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Application Received - {{APP_NAME}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background-color: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .header {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            padding: 32px 24px;
            text-align: center;
            color: white;
        }

        .header h1 {
            font-size: 24px;
            margin: 0;
            font-weight: 600;
        }

        .content {
            padding: 32px 24px;
        }

        .greeting {
            font-size: 16px;
            margin-bottom: 20px;
            color: #333;
        }

        .alert-box {
            background-color: #eff6ff;
            border-left: 4px solid #3b82f6;
            padding: 16px;
            margin: 20px 0;
            border-radius: 4px;
        }

        .alert-box strong {
            color: #1e40af;
            display: block;
            margin-bottom: 8px;
        }

        .job-card {
            background-color: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 20px;
            margin: 24px 0;
        }

        .job-card h3 {
            font-size: 18px;
            color: #1f2937;
            margin-bottom: 12px;
            margin-top: 0;
        }

        .job-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #e5e7eb;
        }

        .detail-item:last-child {
            border-bottom: none;
        }

        .detail-label {
            color: #6b7280;
            font-weight: 500;
        }

        .detail-value {
            color: #1f2937;
            font-weight: 600;
        }

        .applicant-info {
            background-color: #f0f9ff;
            border: 1px solid #bfdbfe;
            border-radius: 6px;
            padding: 16px;
            margin: 20px 0;
        }

        .applicant-info h4 {
            font-size: 14px;
            color: #1e40af;
            margin: 0 0 12px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .applicant-field {
            margin-bottom: 12px;
        }

        .applicant-field:last-child {
            margin-bottom: 0;
        }

        .applicant-field span {
            display: block;
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .applicant-field strong {
            display: block;
            color: #1f2937;
        }

        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            padding: 12px 32px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            margin: 24px 0;
            transition: transform 0.2s;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }

        .footer {
            background-color: #f9fafb;
            padding: 24px;
            text-align: center;
            border-top: 1px solid #e5e7eb;
            font-size: 13px;
            color: #6b7280;
        }

        .footer p {
            margin: 8px 0;
        }

        .divider {
            height: 1px;
            background-color: #e5e7eb;
            margin: 24px 0;
        }

        @media (max-width: 600px) {
            .container {
                border-radius: 0;
            }

            .header {
                padding: 24px 16px;
            }

            .content {
                padding: 24px 16px;
            }

            .footer {
                padding: 16px;
            }

            .detail-item {
                flex-direction: column;
            }

            .detail-value {
                margin-top: 4px;
            }
        }
    </style>
</head> 
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🎉 New Application Received</h1>
        </div>

        <!-- Content -->
        <div class="content">
            <p class="greeting">Hi there,</p>

            <div class="alert-box">
                <strong>You have received a new application!</strong>
                A candidate has submitted their application for the <strong>{{JOB_TITLE}}</strong> position. Review their details below and take the next step in your hiring process.
            </div>

            <!-- Job Information -->
            <div class="job-card">
                <h3>📋 Position Details</h3>
                <div class="job-details">
                    <div class="detail-item">
                        <span class="detail-label">Job Title:</span>
                        <span class="detail-value">{{JOB_TITLE}}</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Application ID:</span>
                        <span class="detail-value">{{APPLICATION._id}}</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Received At:</span>
                        <span class="detail-value">{{APPLICATION.createdAt}}</span>
                    </div>
                </div>
            </div>

            <!-- Applicant Information -->
            <div class="applicant-info">
                <h4>👤 Applicant Information</h4>
                <div class="applicant-field">
                    <span>Full Name</span>
                    <strong>{{APPLICATION.fullName}}</strong>
                </div>
                <div class="applicant-field">
                    <span>Email Address</span>
                    <strong>{{APPLICATION.email}}</strong>
                </div>
                <div class="applicant-field">
                    <span>Phone Number</span>
                    <strong>{{APPLICATION.phoneNumber}}</strong>
                </div>
                {{#if APPLICATION.linkedInUrl}}
                <div class="applicant-field">
                    <span>LinkedIn Profile</span>
                    <strong><a href="{{APPLICATION.linkedInUrl}}" style="color: #3b82f6; text-decoration: none;">View Profile</a></strong>
                </div>
                {{/if}}
                {{#if APPLICATION.country}}
                <div class="applicant-field">
                    <span>Location</span>
                    <strong>{{APPLICATION.city}}, {{APPLICATION.country}}</strong>
                </div>
                {{/if}}
            </div>

            <div style="text-align: center;">
                <a href="{{ACTION_URL}}" class="cta-button">{{ACTION_LABEL}}</a>
            </div>

            <p style="color: #6b7280; font-size: 14px; text-align: center; margin-top: 16px;">
                Click the button above to review the application, check their resume, and take the next step in your hiring process.
            </p>
        </div>

        <!-- Divider -->
        <div class="divider"></div>

        <!-- Footer -->
        <div class="footer">
            <p><strong>{{APP_NAME}}</strong> - Your Hiring Management Platform</p>
            <p>This is an automated message. Please do not reply to this email.</p>
            <p>&copy; {{currentYear}} {{APP_NAME}}. All rights reserved.</p>
        </div>
    </div>
</body>
</html>